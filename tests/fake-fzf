#!/usr/bin/env bash

set -euo pipefail

# Minimal fake fzf used by shell contract tests.

if [[ "${1:-}" == "--help" ]]; then
  cat <<'EOF'
fake fzf
  --header-lines-border
  --listen
  --padding
EOF
  exit 0
fi

while (($# > 0)); do
  case "$1" in
  --filter | --bind)
    shift 2
    ;;
  *)
    shift
    ;;
  esac
done

cat
