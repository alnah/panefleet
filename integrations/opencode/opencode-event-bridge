#!/usr/bin/env bash

set -euo pipefail

# Wrapper kept intentionally thin: fail fast when bridge is missing, then
# delegate OpenCode event interpretation to the Go bridge.

SCRIPT_DIR="$(CDPATH='' cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/../../lib/panefleet/integrations/bridge_wrapper.sh"

panefleet_bridge_wrapper_main "${BASH_SOURCE[0]}" opencode-event opencode 0 "$@"
