#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TARGET="${SCRIPT_DIR}/../integrations/claude/claude-code-hook"

if [[ ! -x "$TARGET" ]]; then
  printf 'panefleet: missing integration wrapper %s\n' "$TARGET" >&2
  exit 1
fi

exec "$TARGET" "$@"
