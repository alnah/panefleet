#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
BRIDGE_BIN="${PANEFLEET_AGENT_BRIDGE_BIN:-$STATE_HOME/panefleet/bin/panefleet-agent-bridge}"
export PANEFLEET_EVENT_LOG_DIR="${PANEFLEET_EVENT_LOG_DIR:-$HOME/.local/state/panefleet/events}"

if [[ ! -x "$BRIDGE_BIN" ]]; then
  printf 'panefleet: missing compiled bridge %s\n' "$BRIDGE_BIN" >&2
  printf 'install it with %s/bin/panefleet install claude\n' "$REPO_ROOT" >&2
  exit 1
fi

exec "$BRIDGE_BIN" claude-hook "$@"
