#!/usr/bin/env bash

set -euo pipefail

# Thin script entrypoint that preserves the stable Codex notify hook path while
# the real integration wrapper lives under integrations/.

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TARGET="${SCRIPT_DIR}/../integrations/codex/codex-notify-bridge"

if [[ ! -x "$TARGET" ]]; then
  printf 'panefleet: missing integration wrapper %s\n' "$TARGET" >&2
  exit 1
fi

exec "$TARGET" "$@"
