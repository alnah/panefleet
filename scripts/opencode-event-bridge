#!/usr/bin/env bash

set -euo pipefail

# Wrapper kept intentionally thin: fail fast when bridge is missing, then
# delegate OpenCode event interpretation to the Go bridge.

SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
BRIDGE_BIN="${PANEFLEET_AGENT_BRIDGE_BIN:-$STATE_HOME/panefleet/bin/panefleet-agent-bridge}"
PANEFLEET_CMD="$(command -v panefleet 2>/dev/null || printf '%s/bin/panefleet' "$REPO_ROOT")"
export PANEFLEET_EVENT_LOG_DIR="${PANEFLEET_EVENT_LOG_DIR:-$HOME/.local/state/panefleet/events}"

if [[ ! -x "$BRIDGE_BIN" ]]; then
  printf 'panefleet: missing compiled bridge %s\n' "$BRIDGE_BIN" >&2
  printf 'install it with %s install opencode\n' "$PANEFLEET_CMD" >&2
  exit 1
fi

exec "$BRIDGE_BIN" opencode-event "$@"
