#!/usr/bin/env bash

set -euo pipefail

# panefleet is a tmux workboard focused on reducing context-switch overhead.
# State detection combines adapter signals (when available) with heuristics so
# core behavior remains functional even without provider-specific integrations.

TMUX_BIN="${TMUX_BIN:-tmux}"
FZF_BIN="${FZF_BIN:-fzf}"
SELF="${BASH_SOURCE[0]:-$0}"
RG_BIN="${RG_BIN:-rg}"

PANEFLEET_SCRIPT_ROOT="$(CDPATH='' cd -- "$(dirname -- "$SELF")/.." && pwd)"
PANEFLEET_LIB_ROOT="${PANEFLEET_SCRIPT_ROOT}/lib/panefleet"

panefleet_require_lib() {
  local relative_path="$1"
  local absolute_path="${PANEFLEET_LIB_ROOT}/${relative_path}"

  if [[ ! -f "$absolute_path" ]]; then
    printf 'panefleet: missing module %s\n' "$absolute_path" >&2
    exit 1
  fi

  # shellcheck disable=SC1090,SC1091
  source "$absolute_path"
}

panefleet_require_lib 'state/engine.sh'
panefleet_require_lib 'runtime/paths.sh'
panefleet_require_lib 'runtime/globals.sh'
panefleet_require_lib 'runtime/base.sh'
panefleet_require_lib 'runtime/requirements.sh'
panefleet_require_lib 'ui/theme_palette.sh'
panefleet_require_lib 'runtime/tmux_state.sh'
panefleet_require_lib 'ui/render.sh'
panefleet_require_lib 'ui/board.sh'
panefleet_require_lib 'ui/go_board.sh'
panefleet_require_lib 'runtime/doctor_support.sh'
panefleet_require_lib 'integrations/install.sh'
panefleet_require_lib 'cli/install.sh'
panefleet_require_lib 'ui/theme_commands.sh'
panefleet_require_lib 'cli/state.sh'

# main keeps CLI routing explicit to preserve a stable command contract for
# wrappers, tests, and tmux hook invocations.
main() {
  local command="${1:-board}"
  local target_pane

  case "$command" in
  board)
    case "$(board_backend)" in
    go)
      run_go_board
      ;;
    shell)
      open_board
      ;;
    *)
      printf 'unsupported board backend: %s\n' "$(board_backend)" >&2
      exit 1
      ;;
    esac
    ;;
  board-go)
    run_go_board
    ;;
  board-shell)
    open_board
    ;;
  board-ticker)
    shift
    board_ticker_command "$@"
    ;;
  popup)
    case "$(board_backend)" in
    go)
      open_go_popup
      ;;
    shell)
      open_popup
      ;;
    *)
      printf 'unsupported board backend: %s\n' "$(board_backend)" >&2
      exit 1
      ;;
    esac
    ;;
  popup-go)
    open_go_popup
    ;;
  popup-shell)
    open_popup
    ;;
  list)
    list_rows
    ;;
  list-deferred)
    PANEFLEET_LIST_MODE=deferred-refresh list_rows
    ;;
  list-board-fast)
    list_board_fast_rows
    ;;
  preview)
    shift
    preview_row "$@"
    ;;
  preview-refresh)
    shift
    preview_refresh_command "$@"
    ;;
  install)
    shift
    install_command "$@"
    ;;
  uninstall)
    shift
    uninstall_command "$@"
    ;;
  state-set)
    shift
    state_set_command "$@"
    ;;
  state-clear)
    shift
    state_clear_command "$@"
    ;;
  metrics-set)
    shift
    usage_metrics_set_command "$@"
    ;;
  metrics-clear)
    shift
    usage_metrics_clear_command "$@"
    ;;
  state-stale)
    shift
    state_stale_command "$@"
    ;;
  state-show)
    shift
    state_show_command "$@"
    ;;
  inspect)
    shift
    state_show_command "$@"
    ;;
  state-list)
    shift
    state_list_command "$@"
    ;;
  jump)
    shift
    jump_to_pane "$@"
    ;;
  themes)
    available_themes
    ;;
  theme-select)
    open_theme_selector
    ;;
  theme-popup)
    open_theme_popup
    ;;
  theme-preview)
    shift
    theme_preview "$@"
    ;;
  theme-apply)
    shift
    apply_theme "$@"
    ;;
  preflight)
    shift
    preflight "$@"
    ;;
  doctor)
    shift
    doctor_command "$@"
    ;;
  refresh-panes-cache)
    shift
    refresh_panes_cache "$@"
    ;;
  queue-refresh)
    shift
    queue_refresh_command "$@"
    ;;
  board-repaint-cache)
    shift
    board_repaint_cache_command "$@"
    ;;
  touch)
    shift
    target_pane="${1:-$("${TMUX_BIN}" display-message -p '#{pane_id}') }"
    target_pane="${target_pane% }"
    set_pane_option "$target_pane" @panefleet_last_touch "$(now_epoch)"
    runtime_log_event "pane_touch" pane "$target_pane"
    queue_refresh_request "panes" "$target_pane"
    ;;
  *)
    printf 'unknown command: %s\n' "$command" >&2
    exit 1
    ;;
  esac
}

if [[ "${PANEFLEET_SOURCE_ONLY:-0}" != "1" ]]; then
  main "$@"
fi
