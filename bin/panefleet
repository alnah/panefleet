#!/usr/bin/env bash

set -euo pipefail

TMUX_BIN="${TMUX_BIN:-tmux}"
FZF_BIN="${FZF_BIN:-fzf}"
SELF="${0}"

require_tmux() {
  if [[ -z "${TMUX:-}" ]]; then
    printf 'panefleet must run inside tmux\n' >&2
    exit 1
  fi
}

manual_status() {
  local pane_id="$1"
  "${TMUX_BIN}" show-options -pt "$pane_id" -v @panefleet_status 2>/dev/null || true
}

tool_kind() {
  local cmd="$1"
  local title="$2"

  case "${cmd}:${title}" in
    codex*:*|codex-aarch64-a:*)
      printf 'codex'
      ;;
    claude*:*|*:*claude*)
      printf 'claude'
      ;;
    opencode:*|open-code:*|*:*opencode*)
      printf 'opencode'
      ;;
    sh:*|bash:*|zsh:*|fish:*|nu:*|tmux:*)
      printf 'shell'
      ;;
    *)
      printf '%s' "$cmd"
      ;;
  esac
}

inferred_status() {
  local cmd="$1"
  local dead="$2"
  local dead_status="$3"

  if [[ "$dead" == "1" ]]; then
    if [[ "$dead_status" == "0" ]]; then
      printf 'DONE'
    else
      printf 'ERROR'
    fi
    return
  fi

  case "$cmd" in
    sh|bash|zsh|fish|nu|tmux)
      printf 'IDLE'
      ;;
    *)
      printf 'RUN'
      ;;
  esac
}

status_rank() {
  case "$1" in
    RUN) printf '0' ;;
    WAIT) printf '1' ;;
    DONE) printf '2' ;;
    ERROR) printf '3' ;;
    IDLE) printf '4' ;;
    *) printf '9' ;;
  esac
}

status_color() {
  case "$1" in
    RUN) printf '\033[1;32m%s\033[0m' "$1" ;;
    WAIT) printf '\033[1;33m%s\033[0m' "$1" ;;
    DONE) printf '\033[90m%s\033[0m' "$1" ;;
    ERROR) printf '\033[1;31m%s\033[0m' "$1" ;;
    IDLE) printf '\033[34m%s\033[0m' "$1" ;;
    *) printf '%s' "$1" ;;
  esac
}

pretty_age() {
  local epoch="$1"
  local now diff

  now="$(date +%s)"
  if [[ -z "$epoch" || "$epoch" == "0" ]]; then
    printf '-'
    return
  fi

  diff=$(( now - epoch ))
  if (( diff < 60 )); then
    printf '%ss' "$diff"
  elif (( diff < 3600 )); then
    printf '%sm' $(( diff / 60 ))
  elif (( diff < 86400 )); then
    printf '%sh' $(( diff / 3600 ))
  else
    printf '%sd' $(( diff / 86400 ))
  fi
}

task_label() {
  local cmd="$1"
  local title="$2"
  local window_name="$3"
  local repo="$4"

  case "$title" in
    ""|"$cmd"|zsh|bash|fish|sh|tmux|cdx)
      if [[ -n "$window_name" && "$window_name" != "$repo" ]]; then
        printf '%s' "$window_name"
      elif [[ -n "$repo" ]]; then
        printf '%s' "$repo"
      else
        printf '%s' "$cmd"
      fi
      ;;
    *)
      printf '%s' "$title"
      ;;
  esac
}

list_rows() {
  "${TMUX_BIN}" list-panes -a -F '#{pane_id}	#{session_name}	#{window_index}	#{window_name}	#{pane_index}	#{pane_current_command}	#{pane_title}	#{pane_current_path}	#{pane_dead}	#{pane_dead_status}	#{window_activity}' |
    while IFS=$'\t' read -r pane_id session_name window_index window_name pane_index cmd title path dead dead_status activity; do
      local_status="$(manual_status "$pane_id")"
      if [[ -n "$local_status" ]]; then
        status="$local_status"
      else
        status="$(inferred_status "$cmd" "$dead" "$dead_status")"
      fi

      repo="$(basename "$path" 2>/dev/null || printf '%s' "$path")"
      tool="$(tool_kind "$cmd" "$title")"
      task="$(task_label "$cmd" "$title" "$window_name" "$repo")"
      target_window="${session_name}:${window_index}"
      target_pane="${target_window}.${pane_index}"
      short_path="${path/#$HOME/\~}"
      age="$(pretty_age "${activity:-0}")"
      colored_status="$(status_color "$status")"
      display="$(printf '%-5b  %-10s  %-20s  %-14s  %-5s  %s' "$colored_status" "$tool" "$target_pane" "$repo" "$age" "$task")"

      printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$pane_id" \
        "$target_window" \
        "$(status_rank "$status")" \
        "${activity:-0}" \
        "$short_path" \
        "$display"
    done |
    sort -t $'\t' -k3,3n -k4,4nr
}

preview_row() {
  local pane_id="${1:?pane_id is required}"
  local status cmd title path short_path session_name window_index pane_index window_name dead dead_status

  status="$(manual_status "$pane_id")"
  cmd="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{pane_current_command}')"
  dead="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{pane_dead}')"
  dead_status="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{pane_dead_status}')"
  if [[ -z "$status" ]]; then
    status="$(inferred_status "$cmd" "$dead" "$dead_status")"
  fi

  session_name="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{session_name}')"
  window_index="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{window_index}')"
  pane_index="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{pane_index}')"
  window_name="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{window_name}')"
  title="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{pane_title}')"
  path="$("${TMUX_BIN}" display-message -p -t "$pane_id" '#{pane_current_path}')"
  short_path="${path/#$HOME/\~}"

  printf 'status  %s\n' "$status"
  printf 'target  %s:%s.%s\n' "$session_name" "$window_index" "$pane_index"
  printf 'window  %s\n' "$window_name"
  printf 'cmd     %s\n' "$cmd"
  printf 'tool    %s\n' "$(tool_kind "$cmd" "$title")"
  printf 'title   %s\n' "$title"
  printf 'path    %s\n' "$short_path"
  printf '\n'
  "${TMUX_BIN}" capture-pane -p -t "$pane_id" -S -40
}

mark_status() {
  local pane_id="${1:?pane_id is required}"
  local status="${2:?status is required}"

  case "$status" in
    RUN|WAIT|DONE|IDLE|ERROR)
      "${TMUX_BIN}" set-option -pt "$pane_id" -q @panefleet_status "$status"
      ;;
    CLEAR)
      "${TMUX_BIN}" set-option -pt "$pane_id" -u @panefleet_status
      ;;
    *)
      printf 'unsupported status: %s\n' "$status" >&2
      exit 1
      ;;
  esac
}

jump_to_pane() {
  local pane_id="${1:?pane_id is required}"
  local target_window="${2:?target_window is required}"

  "${TMUX_BIN}" switch-client -t "$target_window"
  "${TMUX_BIN}" select-pane -t "$pane_id"
}

open_board() {
  require_tmux

  list_rows | "${FZF_BIN}" \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=6 \
    --no-sort \
    --layout=reverse \
    --height=100% \
    --border=none \
    --prompt='panefleet> ' \
    --header=$'enter: jump | alt-r: RUN | alt-w: WAIT | alt-d: DONE | alt-c: clear' \
    --preview "${SELF} preview {1}" \
    --preview-window='bottom,55%,border-top,wrap' \
    --bind "enter:execute-silent(${SELF} jump {1} {2})+abort" \
    --bind "alt-r:execute-silent(${SELF} mark {1} RUN)+reload(${SELF} list)" \
    --bind "alt-w:execute-silent(${SELF} mark {1} WAIT)+reload(${SELF} list)" \
    --bind "alt-d:execute-silent(${SELF} mark {1} DONE)+reload(${SELF} list)" \
    --bind "alt-c:execute-silent(${SELF} mark {1} CLEAR)+reload(${SELF} list)"
}

main() {
  local command="${1:-board}"

  case "$command" in
    board)
      open_board
      ;;
    list)
      list_rows
      ;;
    preview)
      shift
      preview_row "$@"
      ;;
    mark)
      shift
      mark_status "$@"
      ;;
    mark-current)
      shift
      require_tmux
      mark_status "$("${TMUX_BIN}" display-message -p '#{pane_id}')" "$1"
      ;;
    jump)
      shift
      jump_to_pane "$@"
      ;;
    *)
      printf 'unknown command: %s\n' "$command" >&2
      exit 1
      ;;
  esac
}

main "$@"
