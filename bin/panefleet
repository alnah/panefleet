  THEME_NAME="$1"
  THEME_BG="$2"
  THEME_BG_ALT="$3"
  THEME_FG="$4"
  THEME_MUTED="$5"
  THEME_BORDER="$6"
  THEME_ACCENT="$7"
  THEME_HEADER="$8"
  THEME_SELECTION_BG="$9"
  THEME_SELECTION_FG="${10}"
  THEME_RUN="${11}"
  THEME_WAIT="${12}"
  THEME_DONE="${13}"
  THEME_ERROR="${14}"
  THEME_IDLE="${15}"
  THEME_STALE="${16}"
  THEME_DIFF_HEADER="${17}"
  THEME_DIFF_ADD="${18}"
  THEME_DIFF_REMOVE="${19}"
  THEME_DIFF_HUNK="${20}"
}

